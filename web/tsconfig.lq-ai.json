{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true
  },
  // Scoped typecheck config: covers only LQ.AI-owned code.
  // Inheriting `include` from parent does NOT work (TypeScript does not merge
  // include arrays); so we list explicitly: SvelteKit ambient types that must
  // always be present for path resolution, plus the LQ.AI source subtrees.
  //
  // Run:   npm run check:lq-ai    (CI gate — must stay at 0 errors)
  // Full:  npm run check          (all ~9 k upstream errors, migration tracking)
  "include": [
    ".svelte-kit/ambient.d.ts",
    ".svelte-kit/non-ambient.d.ts",
    ".svelte-kit/types/**/$types.d.ts",
    "src/app.d.ts",
    "src/lib/lq-ai/**/*.js",
    "src/lib/lq-ai/**/*.ts",
    "src/lib/lq-ai/**/*.svelte",
    "src/routes/lq-ai/**/*.js",
    "src/routes/lq-ai/**/*.ts",
    "src/routes/lq-ai/**/*.svelte"
  ],
  "exclude": [
    "node_modules/**"
  ]
}
