# =============================================================================
# .env.prod.example — hosted tenant stack (SAAS-3, ADR-F060 D6)
# =============================================================================
# Copy to a ROOT-OWNED, chmod-600 .env.prod ON THE NODE (never in the repo). This
# file ships PLACEHOLDERS ONLY — the public repo must never carry a real secret
# (the .env.bak leak is the standing lesson). Fill the REPLACE_ME__* values:
#   - generated secrets: run  scripts/gen-secrets.sh >> /opt/lq-ai/.env.prod
#   - procured values: paste from the provider consoles (DNS + object storage).
# `docker compose -f docker-compose.prod.yml --env-file .env.prod config` must
# succeed once this is filled in (required vars use ${VAR:?} in the compose file).
# Private profile (restricted-egress, no public URL / external S3 — ADR-F070):
# see .env.private.example instead.

# --- Deploy pin --------------------------------------------------------------
# The image SHA to run. deploy.sh sets this per deploy (a sha-<12hex> tag from
# images.yml); needed here only for a manual `docker compose` on the node.
LQ_AI_IMAGE_TAG=sha-REPLACE_ME

# --- Generated secrets (scripts/gen-secrets.sh) ------------------------------
POSTGRES_PASSWORD=REPLACE_ME__gen-secrets
JWT_SECRET=REPLACE_ME__gen-secrets
LQ_AI_GATEWAY_KEY=REPLACE_ME__gen-secrets
# Optional (ADR-F060 D6): decrypts api_key_encrypted: provider keys in gateway.yaml.
# Leave empty to use the plaintext provider-key env vars below instead.
LQ_AI_GATEWAY_MASTER_KEY=
COLLABORA_ADMIN_USER=lqops
COLLABORA_ADMIN_PASSWORD=REPLACE_ME__gen-secrets

# --- Public identity + TLS (caddy edge) --------------------------------------
# The hostname Caddy serves + provisions the wildcard cert for. Single host for
# staging; a wildcard (*.tenant.example.com) for a multi-subdomain prod tenant.
LQ_AI_PUBLIC_HOST=staging.example.com
# Same public host WITHOUT a scheme, for Collabora's server_name / frame-ancestors.
LQ_AI_PUBLIC_ORIGIN=staging.example.com
# ACME account email for Let's Encrypt cert-expiry notices.
LQ_AI_ACME_EMAIL=ops@example.com
# DNS provider answering the ACME DNS-01 challenge — where this tenant's DNS
# ZONE is hosted (independent of the VPS vendor). Must be compiled into the
# lq-ai-caddy image: hetzner | ionos (SETUP-1).
LQ_AI_DNS_PROVIDER=hetzner
# API token for that DNS provider, scoped to this zone. IONOS tokens are the
# "publicprefix.secret" concatenation from the IONOS developer console.
LQ_AI_DNS_API_TOKEN=REPLACE_ME__dns_api_token

# --- Object storage (Hetzner Object Storage or any S3-compatible) ------------
S3_ENDPOINT_URL=https://REPLACE_ME.your-objectstorage.example.com
S3_ACCESS_KEY=REPLACE_ME__s3_access_key
S3_SECRET_KEY=REPLACE_ME__s3_secret_key
# Per-tenant bucket (ADR-F058 day-one rule); objects keyed tenants/<id>/<file_id>.
S3_BUCKET=REPLACE_ME__tenant_bucket
# Provider region code (e.g. Hetzner fsn1 / nbg1 / hel1 — not always an AWS region).
S3_REGION=fsn1

# --- Gateway config + provider keys ------------------------------------------
# Path ON THE NODE to this tenant's provisioned gateway.yaml seed (control-plane
# template). The named volume holds the live, writable copy across restarts.
GATEWAY_CONFIG_FILE=/opt/lq-ai/gateway.yaml
# Provider keys — plaintext here OR (preferred) Fernet-encrypted in gateway.yaml
# with LQ_AI_GATEWAY_MASTER_KEY. Any may stay empty; gateway.yaml picks the model.
# PUBLIC-URL FENCING (ADR-F060 consequences, SAAS-6): do NOT default staging tenant
# traffic to a PRC provider — keep MINIMAX/DEEPSEEK unset unless deliberately used.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_RESOURCE=
# Azure AI Foundry — Claude (AZ-CONFIG). Resource NAME only (the <your-resource>
# part of https://<your-resource>.services.ai.azure.com); region must be
# East US2 or Sweden Central. Chat-only until slice AZ-2b adds tool translation.
AZURE_ANTHROPIC_API_KEY=
AZURE_ANTHROPIC_RESOURCE=
# Azure AI Foundry — non-OpenAI Foundry Models, e.g. Mistral-Large-3
# (AZ-CONFIG). Resource NAME only, served on the classic deployments route.
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_RESOURCE=
# OPTIONAL (KV-1, ADR-F069) — source the three Azure keys from Azure Key Vault
# instead of the plaintext AZURE_*_API_KEY vars above. All NON-secret. Set the
# vault NAME (the <name> in https://<name>.vault.azure.net) plus, per key, the
# secret NAME holding it; the gateway then fetches that key at startup via the
# VM's system-assigned managed identity (IMDS) so it never lives on disk. Leave a
# pair unset to keep reading its plain AZURE_*_API_KEY var (default behavior).
# Requires the VM's system-assigned identity to hold the "Key Vault Secrets User"
# role on the vault. See docs/fork/runbooks/azure-vm-sandbox.md §4b.
# AZURE_KEY_VAULT_NAME=<your-vault-name>
# AZURE_OPENAI_KEY_SECRET_NAME=<secret-name-holding-the-azure-openai-key>
# AZURE_ANTHROPIC_KEY_SECRET_NAME=<secret-name-holding-the-azure-anthropic-key>
# AZURE_FOUNDRY_KEY_SECRET_NAME=<secret-name-holding-the-azure-foundry-key>
# OPTIONAL (AZ-6, ADR-F072) — keyless: authenticate the azure-openai provider with
# the VM's system-assigned managed identity instead of a key. When true, NO
# AZURE_OPENAI_API_KEY (nor a Key Vault secret) is needed; the gateway mints a
# short-lived Entra bearer token from IMDS (~1h, auto-refreshed). Requires the VM
# identity to hold the "Cognitive Services OpenAI User" role (MODEL INFERENCE) on
# the Foundry/AOAI resource — NOT just "Key Vault Secrets User". Optional audience
# override defaults to https://cognitiveservices.azure.com (classic route); set
# https://ai.azure.com for the /openai/v1/ route. See runbook §4c.
# AZURE_OPENAI_USE_MANAGED_IDENTITY=true
# AZURE_OPENAI_IDENTITY_RESOURCE=https://cognitiveservices.azure.com
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=

# --- Retrieval (ADR-F049 C1/D) — local ONNX = $0, no extra egress ------------
EMBEDDING_PROVIDER=local
RERANK_ENABLED=true

# --- Auth + notification email (SETUP-2) -------------------------------------
# FIRST_RUN_ADMIN_EMAIL seeds the CUSTOMER admin at first boot (config.py has no
# env_prefix — bare field name). Unset ⇒ default admin@lq.ai.
FIRST_RUN_ADMIN_EMAIL=admin@example.com
# FIRST_RUN_OPERATOR_EMAIL seeds the PLATFORM operator account (SETUP-3a) — the
# only account allowed to touch gateway surfaces (aliases/provider-keys/config/
# tier-policy). Unset ⇒ no operator is bootstrapped.
FIRST_RUN_OPERATOR_EMAIL=operator@example.com
# PUBLIC_BASE_URL is the browser-facing base for emailed invite/reset links.
# Leave unset to derive https://${LQ_AI_PUBLIC_ORIGIN} in the compose; set here to
# override (must include the scheme). Unset+no origin ⇒ path-only fallback links.
PUBLIC_BASE_URL=https://staging.example.com
# SMTP for auth/notification mail — OPTIONAL, gated on SMTP_HOST. Leave SMTP_HOST
# empty to disable (in-app notifications still work). SMTP_FROM falls back to
# SMTP_USERNAME when unset. Fill the password ONLY when you actually enable SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=REPLACE_ME__smtp_password
SMTP_FROM=
SMTP_USE_TLS=true

# --- Auth / rate-limit knobs (secure code defaults; tune under attack) --------
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=604800
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_IP_PER_WINDOW=10
RATE_LIMIT_LOGIN_ACCOUNT_PER_WINDOW=5
RATE_LIMIT_REFRESH_IP_PER_WINDOW=60
RATE_LIMIT_MFA_VERIFY_IP_PER_WINDOW=10
RATE_LIMIT_MFA_VERIFY_ACCOUNT_PER_WINDOW=5
RATE_LIMIT_CHANGE_PASSWORD_ACCOUNT_PER_WINDOW=5
RATE_LIMIT_MFA_MANAGE_ACCOUNT_PER_WINDOW=10
RATE_LIMIT_BOOTSTRAP_STATUS_IP_PER_WINDOW=30
# SETUP-3a (ADR-F061 D7) — lifecycle token TTLs + rate limits.
INVITE_TOKEN_TTL_SECONDS=604800
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600
RATE_LIMIT_PASSWORD_RESET_REQUEST_IP_PER_WINDOW=10
RATE_LIMIT_PASSWORD_RESET_REQUEST_EMAIL_PER_WINDOW=5
RATE_LIMIT_TOKEN_REDEEM_IP_PER_WINDOW=10
# SETUP-5a (ADR-F063) — deployment default budget profile for new agent runs
# (economy | balanced | generous). Empty/unset ⇒ balanced. Overridden by a
# practice area's default_budget_profile and by an explicit per-run choice.
RUN_DEFAULT_BUDGET_PROFILE=

# --- White-label branding seed (BRAND-1a, ADR-F068) ---------------------------
# Optional: applied ONCE at first boot while the branding table is empty; admin
# UI edits always win afterwards. Name 1-80 chars of letters/digits/space/dot/
# underscore/dash (QUOTE it when it carries spaces — this file is sourced);
# accents are #RRGGBB hex. Logo upload is an admin-page action post-boot.
BRAND_PRODUCT_NAME=
BRAND_ACCENT_LIGHT=
BRAND_ACCENT_DARK=

# --- Trusted proxy + CORS ----------------------------------------------------
# SAAS-3b hardening: pin this to Caddy's fixed container IP (drop the * default)
# once the live stack IP is known (ADR-F059 D4). Same-origin serving ⇒ no CORS.
FORWARDED_ALLOW_IPS=*
LQ_AI_CORS_ORIGINS=
# api HTTP keep-alive timeout (seconds). MUST exceed the fronting proxy's upstream
# idle timeout (Caddy default ~120s) so the proxy — never the server mid-request —
# closes idle connections; otherwise a reused-after-close connection surfaces as a
# sporadic "Failed to fetch" in the SPA. Default 130 clears Caddy; raise it if your
# proxy idles longer. (Read by api/entrypoint.sh.)
LQ_AI_HTTP_KEEP_ALIVE_TIMEOUT=130

# --- Collabora extras (prod defaults; usually leave as-is) --------------------
COLLABORA_SSL_TERMINATION=true
COLLABORA_HOME_MODE=true

# --- Observability (opt-in; unset disables) ----------------------------------
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# --- Backups + ops (read by scripts/backup.sh|restore-drill.sh, NOT compose) --
# Per-tenant object key prefix for backups (tenants/<id>/backups/…).
LQ_AI_TENANT_ID=REPLACE_ME__tenant_id
# age PUBLIC recipient (age1…) — backup.sh encrypts to this; the node never holds
# the private identity. Generate offline with `age-keygen`; keep the identity safe.
LQ_AI_BACKUP_AGE_RECIPIENT=age1REPLACE_ME__public_recipient
# healthchecks.io-style dead-man ping URLs (optional but recommended).
LQ_AI_BACKUP_DEADMAN_URL=
LQ_AI_RESTORE_DEADMAN_URL=
# Where the compose + scripts live on the node, and the per-tenant compose project.
LQ_AI_STACK_DIR=/opt/lq-ai
COMPOSE_PROJECT_NAME=lq-ai
# NOTE: restore-drill.sh also needs LQ_AI_BACKUP_AGE_IDENTITY (the PRIVATE key
# file path). Provide it AD HOC when running a drill — do NOT persist the private
# key in this file.

# --- Postgres/Redis identity (defaults; override only if you must) -----------
POSTGRES_DB=lq_ai
POSTGRES_USER=lq_ai
