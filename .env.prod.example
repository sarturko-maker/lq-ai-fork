# =============================================================================
# .env.prod.example — hosted tenant stack (SAAS-3, ADR-F060 D6)
# =============================================================================
# Copy to a ROOT-OWNED, chmod-600 .env.prod ON THE NODE (never in the repo). This
# file ships PLACEHOLDERS ONLY — the public repo must never carry a real secret
# (the .env.bak leak is the standing lesson). Fill the REPLACE_ME__* values:
#   - generated secrets: run  scripts/gen-secrets.sh >> /opt/lq-ai/.env.prod
#   - procured values: paste from the provider consoles (DNS + object storage).
# `docker compose -f docker-compose.prod.yml --env-file .env.prod config` must
# succeed once this is filled in (required vars use ${VAR:?} in the compose file).

# --- Deploy pin --------------------------------------------------------------
# The image SHA to run. deploy.sh sets this per deploy (a sha-<12hex> tag from
# images.yml); needed here only for a manual `docker compose` on the node.
LQ_AI_IMAGE_TAG=sha-REPLACE_ME

# --- Generated secrets (scripts/gen-secrets.sh) ------------------------------
POSTGRES_PASSWORD=REPLACE_ME__gen-secrets
JWT_SECRET=REPLACE_ME__gen-secrets
LQ_AI_GATEWAY_KEY=REPLACE_ME__gen-secrets
# Optional (ADR-F060 D6): decrypts api_key_encrypted: provider keys in gateway.yaml.
# Leave empty to use the plaintext provider-key env vars below instead.
LQ_AI_GATEWAY_MASTER_KEY=
COLLABORA_ADMIN_USER=lqops
COLLABORA_ADMIN_PASSWORD=REPLACE_ME__gen-secrets

# --- Public identity + TLS (caddy edge) --------------------------------------
# The hostname Caddy serves + provisions the wildcard cert for. Single host for
# staging; a wildcard (*.tenant.example.com) for a multi-subdomain prod tenant.
LQ_AI_PUBLIC_HOST=staging.example.com
# Same public host WITHOUT a scheme, for Collabora's server_name / frame-ancestors.
LQ_AI_PUBLIC_ORIGIN=staging.example.com
# ACME account email for Let's Encrypt cert-expiry notices.
LQ_AI_ACME_EMAIL=ops@example.com
# DNS provider answering the ACME DNS-01 challenge — where this tenant's DNS
# ZONE is hosted (independent of the VPS vendor). Must be compiled into the
# lq-ai-caddy image: hetzner | ionos (SETUP-1).
LQ_AI_DNS_PROVIDER=hetzner
# API token for that DNS provider, scoped to this zone. IONOS tokens are the
# "publicprefix.secret" concatenation from the IONOS developer console.
LQ_AI_DNS_API_TOKEN=REPLACE_ME__dns_api_token

# --- Object storage (Hetzner Object Storage or any S3-compatible) ------------
S3_ENDPOINT_URL=https://REPLACE_ME.your-objectstorage.example.com
S3_ACCESS_KEY=REPLACE_ME__s3_access_key
S3_SECRET_KEY=REPLACE_ME__s3_secret_key
# Per-tenant bucket (ADR-F058 day-one rule); objects keyed tenants/<id>/<file_id>.
S3_BUCKET=REPLACE_ME__tenant_bucket
# Provider region code (e.g. Hetzner fsn1 / nbg1 / hel1 — not always an AWS region).
S3_REGION=fsn1

# --- Gateway config + provider keys ------------------------------------------
# Path ON THE NODE to this tenant's provisioned gateway.yaml seed (control-plane
# template). The named volume holds the live, writable copy across restarts.
GATEWAY_CONFIG_FILE=/opt/lq-ai/gateway.yaml
# Provider keys — plaintext here OR (preferred) Fernet-encrypted in gateway.yaml
# with LQ_AI_GATEWAY_MASTER_KEY. Any may stay empty; gateway.yaml picks the model.
# PUBLIC-URL FENCING (ADR-F060 consequences, SAAS-6): do NOT default staging tenant
# traffic to a PRC provider — keep MINIMAX/DEEPSEEK unset unless deliberately used.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_RESOURCE=
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=

# --- Retrieval (ADR-F049 C1/D) — local ONNX = $0, no extra egress ------------
EMBEDDING_PROVIDER=local
RERANK_ENABLED=true

# --- Auth / rate-limit knobs (secure code defaults; tune under attack) --------
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=604800
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_IP_PER_WINDOW=10
RATE_LIMIT_LOGIN_ACCOUNT_PER_WINDOW=5
RATE_LIMIT_REFRESH_IP_PER_WINDOW=60
RATE_LIMIT_MFA_VERIFY_IP_PER_WINDOW=10
RATE_LIMIT_MFA_VERIFY_ACCOUNT_PER_WINDOW=5
RATE_LIMIT_CHANGE_PASSWORD_ACCOUNT_PER_WINDOW=5
RATE_LIMIT_MFA_MANAGE_ACCOUNT_PER_WINDOW=10
RATE_LIMIT_BOOTSTRAP_STATUS_IP_PER_WINDOW=30

# --- Trusted proxy + CORS ----------------------------------------------------
# SAAS-3b hardening: pin this to Caddy's fixed container IP (drop the * default)
# once the live stack IP is known (ADR-F059 D4). Same-origin serving ⇒ no CORS.
FORWARDED_ALLOW_IPS=*
LQ_AI_CORS_ORIGINS=

# --- Collabora extras (prod defaults; usually leave as-is) --------------------
COLLABORA_SSL_TERMINATION=true
COLLABORA_HOME_MODE=true

# --- Observability (opt-in; unset disables) ----------------------------------
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# --- Backups + ops (read by scripts/backup.sh|restore-drill.sh, NOT compose) --
# Per-tenant object key prefix for backups (tenants/<id>/backups/…).
LQ_AI_TENANT_ID=REPLACE_ME__tenant_id
# age PUBLIC recipient (age1…) — backup.sh encrypts to this; the node never holds
# the private identity. Generate offline with `age-keygen`; keep the identity safe.
LQ_AI_BACKUP_AGE_RECIPIENT=age1REPLACE_ME__public_recipient
# healthchecks.io-style dead-man ping URLs (optional but recommended).
LQ_AI_BACKUP_DEADMAN_URL=
LQ_AI_RESTORE_DEADMAN_URL=
# Where the compose + scripts live on the node, and the per-tenant compose project.
LQ_AI_STACK_DIR=/opt/lq-ai
COMPOSE_PROJECT_NAME=lq-ai
# NOTE: restore-drill.sh also needs LQ_AI_BACKUP_AGE_IDENTITY (the PRIVATE key
# file path). Provide it AD HOC when running a drill — do NOT persist the private
# key in this file.

# --- Postgres/Redis identity (defaults; override only if you must) -----------
POSTGRES_DB=lq_ai
POSTGRES_USER=lq_ai
