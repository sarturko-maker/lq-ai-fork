.parcel-cache/
.turbo/
out/

# ---------- Environment & secrets ----------
# .env is the operator's local config; never commit
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
# Catch EVERY other .env.<suffix> — backups, dumps, env-specific copies. The
# `.env.bak-f0-s4` leak (committed in PR #35) matched none of the patterns
# above and exposed the live MiniMax/JWT/gateway/Postgres secrets once the
# repo went public. `.env.*` closes that whole class. (SECURITY)
.env.*
# ...but the committed templates (root + deploy/*) stay tracked.
!.env.example
# The hosted-deploy template — PLACEHOLDERS ONLY, enforced by the guard test
# api/tests/test_env_prod_example.py (SAAS-3, ADR-F060 D6).
!.env.prod.example

# Operator's actual gateway.yaml (the .example version is committed)
gateway.yaml
config.yaml

# Local development overrides
docker-compose.override.yml
gateway.local.yaml
config.local.yaml

# Certificates and keys
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.secrets/

# ---------- IDEs ----------
.idea/
.vscode/
.claude/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.iml
*.ipr
*.iws
.history/

# ---------- OS ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# macOS Finder duplicate files. On iCloud-synced trees, Finder
# occasionally creates phantom duplicates named "foo 2.py", "foo 3.ts",
# "foo 4.svelte", etc., when it perceives a conflict. These break
# Alembic head resolution, Python imports, Vite imports, and docker
# builds (see api/.dockerignore + gateway/.dockerignore + web/.dockerignore
# for the build-time guard). This pattern keeps them out of git.
* [0-9].*
* [0-9][0-9].*

# ---------- Operator-private content ----------
# Test corpus is the operator's anonymized real documents; per
# docs/acceptance-testing-framework.md, this stays local and
# is documented in test plans, not committed.
test-corpus/
test-results/

# Operator-generated runtime data (runtime artifacts only — do NOT
# ignore application-bundled data such as ``api/app/data/`` which
# ships templates and fixtures inside the api package).
data/
!api/app/data/
logs/
uploads/
postgres-data/
redis-data/
minio-data/

# ---------- Launch-staging content ----------
# These folder names should NEVER appear in the repo. The
# launch-staging content (LinkedIn drafts, GitHub issue
# bodies pasted into Issues UI) lives in a separate local
# folder per FILE-MANIFEST.md. These ignore patterns are
# defense-in-depth in case content gets accidentally copied.
lq-ai-launch/
launch-staging/
linkedin-*.md
issues-staging/

# Internal positioning + engineering-discipline reference docs.
# Used to inform the *style* of public docs (transparent gap
# framing, defensive posture against commercial comparisons) but
# never published. Treat as operator-private.
docs/PRD_Addendum_Engineering_Discipline.md
docs/LaunchPositioning_TwoAxesOfTrust.md

# Internal planning artifacts (audit reports, foundation-readiness
# analyses, backlog inventories produced by `.planning/` workflows).
# These are working notes by definition — never published.
.planning/

# ---------- Eval corpora (fetched, never committed) ----------
# CUAD retrieval-eval corpus (CC-BY-4.0; fetched by scripts/fetch_cuad.sh).
# Multi-MB third-party dataset — used only by the Track-B eval (ADR-F049),
# never shipped. See NOTICES.md § Eval / test datasets.
api/tests/fixtures/cuad/

