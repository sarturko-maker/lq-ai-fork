# ============================================================
# LQ.AI — .gitignore
# ============================================================
# Conventions:
#   - Keep this file at the repo root.
#   - Do not let operator data or launch-staging content reach the repo.
#   - Use .gitkeep files to preserve empty directories that should exist.
# ============================================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# Anchored to root so it ignores Python venv `lib/` directories at the
# project root (and per-subsystem) without reaching into `web/src/lib/`,
# which is OpenWebUI's tracked Svelte library.
/lib/
/api/lib/
/gateway/lib/
/scripts/lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

