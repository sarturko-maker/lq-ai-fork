# ============================================================
# LQ.AI — .gitignore
# ============================================================
# Conventions:
#   - Keep this file at the repo root.
#   - Do not let operator data or launch-staging content reach the repo.
#   - Use .gitkeep files to preserve empty directories that should exist.
# ============================================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Testing & coverage
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
htmlcov/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Linting
.ruff_cache/
.pylintrc

# Jupyter
.ipynb_checkpoints
profile_default/
ipython_config.py

# ---------- Node / JavaScript ----------
node_modules/
.npm/
.yarn/
.pnp/
.pnp.js
yarn-debug.log*
yarn-error.log*
npm-debug.log*
package-lock.json.bak

# Build outputs
.next/
.nuxt/
.svelte-kit/
.parcel-cache/
.turbo/
out/

# ---------- Environment & secrets ----------
# .env is the operator's local config; never commit
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# Operator's actual gateway.yaml (the .example version is committed)
gateway.yaml
config.yaml

# Local development overrides
docker-compose.override.yml
gateway.local.yaml
config.local.yaml

# Certificates and keys
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.secrets/

# ---------- IDEs ----------
.idea/
.vscode/
.claude/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.iml
*.ipr
*.iws
.history/

# ---------- OS ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------- Operator-private content ----------
# Test corpus is the operator's anonymized real documents; per
# docs/acceptance-testing-framework.md, this stays local and
# is documented in test plans, not committed.
test-corpus/
test-results/

# Operator-generated runtime data
data/
logs/
uploads/
postgres-data/
redis-data/
minio-data/

# ---------- Launch-staging content ----------
# These folder names should NEVER appear in the repo. The
# launch-staging content (LinkedIn drafts, GitHub issue
# bodies pasted into Issues UI) lives in a separate local
# folder per FILE-MANIFEST.md. These ignore patterns are
# defense-in-depth in case content gets accidentally copied.
lq-ai-launch/
launch-staging/
linkedin-*.md
issues-staging/

# ---------- Temporary / scratch ----------
tmp/
temp/
scratch/
*.tmp
*.bak
*.orig
*.draft

# ---------- Generated artifacts ----------
docs/_build/
docs/build/
site/
*.generated.md

# ---------- Tool-specific ----------
# Pre-commit
.pre-commit-cache/

# direnv
.envrc
.direnv/

# Cython debug
cython_debug/

# Local TLS / dev certs
*.local.pem
*.local.key
localhost.pem
localhost.key

# Backup files from editors and merge tools
*.swp
*.swo
*.swn
*.un~
.*~
*.orig
*.rej

# ---------- Cleanup pip / package manager artifacts ----------
pip-log.txt
pip-delete-this-directory.txt
