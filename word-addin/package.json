{
  "name": "@legalquants/word-addin",
  "version": "0.3.0-dev",
  "private": true,
  "description": "LQ.AI Word add-in — Office.js task pane delivering chat, skills, and playbook execution against the open document.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/LegalQuants/lq-ai.git",
    "directory": "word-addin"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "webpack --mode=production",
    "build:dev": "webpack --mode=development",
    "watch": "webpack --mode=development --watch",
    "dev-server": "webpack serve --mode=development",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,css,html}' 'manifest.xml'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css,html}' 'manifest.xml'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.470",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-office-addins": "^4.1.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.3",
    "office-addin-cli": "^1.6.7",
    "office-addin-debugging": "^5.1.18",
    "office-addin-dev-certs": "^1.13.4",
    "office-addin-manifest": "^1.13.7",
    "prettier": "^3.3.3",
    "source-map-loader": "^5.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "jsdom": "^25.0.1",
    "webpack": "^5.97.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0"
  }
}
