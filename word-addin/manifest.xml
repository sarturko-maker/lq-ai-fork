<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  LQ.AI Word add-in manifest (XML 1.1+ schema).

  Per Phase B Decision B-2 (2026-05-21 prep doc): we ship the XML manifest
  as the production path for v0.3.0. The JSON unified manifest is still in
  preview for Word as of early 2026; migration is a DE follow-on once GA.

  Templating: double-brace tokens (see the four below) are substituted
  by the LQ.AI admin UI's "Generate manifest" flow
  (GET /api/v1/admin/word-addin/manifest) so an operator can sideload
  via Microsoft 365 Admin Center without hand-editing the XML.

  Tokens substituted at install time:
    {{ ADDIN_ID }}             — GUID per deployment (lowercase, hyphenated)
    {{ DEPLOYMENT_ORIGIN }}     — operator's deployment URL (no trailing /)
    {{ DEPLOYMENT_DISPLAY_NAME }} — operator's branded name (default "LQ.AI")
    {{ PROVIDER_NAME }}         — typically "LegalQuants" or the operator org
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">

  <!-- Per-deployment GUID — generated by the admin UI. -->
  <Id>{{ ADDIN_ID }}</Id>

  <Version>0.3.0.0</Version>
  <ProviderName>{{ PROVIDER_NAME }}</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>

  <DisplayName DefaultValue="{{ DEPLOYMENT_DISPLAY_NAME }}" />
  <Description DefaultValue="Open-source AI for in-house legal teams. Chat, skills, and playbooks against the open document — running on the self-hosted LQ.AI deployment." />

  <IconUrl DefaultValue="{{ DEPLOYMENT_ORIGIN }}/word-addin/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="{{ DEPLOYMENT_ORIGIN }}/word-addin/assets/icon-80.png" />
  <SupportUrl DefaultValue="https://github.com/LegalQuants/lq-ai" />

  <!-- Domains the add-in may navigate to. The deployment origin is the
       primary domain; future expansion (OAuth dialog popup target, etc.)
       lands as separate <AppDomain> entries when M3-B2 ships. -->
  <AppDomains>
    <AppDomain>{{ DEPLOYMENT_ORIGIN }}</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Document" />
  </Hosts>

  <DefaultSettings>
    <SourceLocation DefaultValue="{{ DEPLOYMENT_ORIGIN }}/word-addin/taskpane.html" />
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title" />
            <Description resid="GetStarted.Description" />
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl" />
          </GetStarted>

          <FunctionFile resid="Commands.Url" />

          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="LqAiGroup">
                <Label resid="LqAiGroup.Label" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
                  <bt:Image size="32" resid="Icon.32x32" />
                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>

                <Control xsi:type="Button" id="OpenTaskPaneButton">
                  <Label resid="OpenTaskPaneButton.Label" />
                  <Supertip>
                    <Title resid="OpenTaskPaneButton.Label" />
                    <Description resid="OpenTaskPaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>LqAiTaskpane</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="{{ DEPLOYMENT_ORIGIN }}/word-addin/assets/icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="{{ DEPLOYMENT_ORIGIN }}/word-addin/assets/icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="{{ DEPLOYMENT_ORIGIN }}/word-addin/assets/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="{{ DEPLOYMENT_ORIGIN }}/word-addin/commands.html" />
        <bt:Url id="Taskpane.Url" DefaultValue="{{ DEPLOYMENT_ORIGIN }}/word-addin/taskpane.html" />
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://github.com/LegalQuants/lq-ai" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="{{ DEPLOYMENT_DISPLAY_NAME }} is ready to help." />
        <bt:String id="LqAiGroup.Label" DefaultValue="{{ DEPLOYMENT_DISPLAY_NAME }}" />
        <bt:String id="OpenTaskPaneButton.Label" DefaultValue="Open {{ DEPLOYMENT_DISPLAY_NAME }}" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="Click 'Open LQ.AI' on the Home tab to chat with, run skills on, or apply playbooks to the open document." />
        <bt:String id="OpenTaskPaneButton.Tooltip" DefaultValue="Open the LQ.AI task pane to work with the current document." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>

</OfficeApp>
