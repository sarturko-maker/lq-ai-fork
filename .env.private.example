# =============================================================================
# .env.private.example — PRIVATE profile (restricted-egress self-host, P-1/ADR-F070)
# =============================================================================
# The env-file template for composing docker-compose.private.yml ON TOP of
# docker-compose.prod.yml: same pinned images, NO public URL (Caddy internal TLS
# on loopback :8443, access via SSH tunnel) and NO external S3 (on-box MinIO).
# For locked-down environments where external integrations are signoff-gated.
# Runbook: docs/fork/runbooks/azure-vm-sandbox.md §8.
#
# Copy to a ROOT-OWNED, chmod-600 .env.private ON THE BOX (never in the repo).
# PLACEHOLDERS ONLY here — the public repo must never carry a real secret.
#   - generated secrets: bash scripts/gen-secrets.sh --private >> /opt/lq-ai/.env.private
#     (the --private flag adds the MinIO/S3 credentials block)
#   - then fill the remaining REPLACE_ME__* values below.
# Parse check (required vars use ${VAR:?} in the compose files):
#   docker compose -f docker-compose.prod.yml -f docker-compose.private.yml \
#     --env-file .env.private config

# --- Deploy pin --------------------------------------------------------------
# The image SHA to run — a published sha-<12hex> tag from images.yml, never :main.
LQ_AI_IMAGE_TAG=sha-REPLACE_ME

# --- Generated secrets (scripts/gen-secrets.sh) ------------------------------
POSTGRES_PASSWORD=REPLACE_ME__gen-secrets
JWT_SECRET=REPLACE_ME__gen-secrets
LQ_AI_GATEWAY_KEY=REPLACE_ME__gen-secrets
# Optional (ADR-F060 D6): decrypts api_key_encrypted: provider keys in gateway.yaml.
# Leave empty to use the plaintext provider-key env vars below instead.
LQ_AI_GATEWAY_MASTER_KEY=
COLLABORA_ADMIN_USER=lqops
COLLABORA_ADMIN_PASSWORD=REPLACE_ME__gen-secrets

# --- Object storage: ON-BOX MinIO (private profile) --------------------------
# The overlay adds a `minio` service; these root credentials come from
# `gen-secrets.sh --private`. S3_ACCESS_KEY/S3_SECRET_KEY MUST equal
# MINIO_ROOT_USER/MINIO_ROOT_PASSWORD (the api authenticates to MinIO with
# them; gen-secrets emits matching pairs).
MINIO_ROOT_USER=REPLACE_ME__gen-secrets
MINIO_ROOT_PASSWORD=REPLACE_ME__gen-secrets
# S3_* still satisfy the prod file's ${VAR:?} interpolation — pointed in-stack.
# The bucket is auto-created by the api on first boot (ensure_bucket lifespan).
# S3_ACCESS_KEY = MINIO_ROOT_USER and S3_SECRET_KEY = MINIO_ROOT_PASSWORD.
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=REPLACE_ME__gen-secrets
S3_SECRET_KEY=REPLACE_ME__gen-secrets
S3_BUCKET=lq-ai
S3_REGION=us-east-1

# --- Origin + loopback port (tunnel access) ----------------------------------
# The browser origin is the SSH tunnel end: https://127.0.0.1:8443. Collabora's
# server_name/frame_ancestors and the api's PUBLIC_BASE_URL derive from
# LQ_AI_PUBLIC_ORIGIN (no scheme), so invite/reset links and the in-app editor
# work over the tunnel. Keep the two lines consistent if you change the port.
LQ_AI_PUBLIC_ORIGIN=127.0.0.1:8443
# Host loopback port the caddy service publishes (container always :8443).
LQ_AI_PRIVATE_PORT=8443

# --- Inert public-edge placeholders (NEVER used in this profile) --------------
# docker-compose.prod.yml interpolates these with ${VAR:?} at PARSE time, so
# values must exist — but the private overlay mounts Caddyfile.private, which
# references none of them: no ACME account is registered, no DNS API is called,
# no public hostname is served. They are parse-time ballast only; leave them
# exactly as below. (.invalid is a reserved TLD — can never resolve.)
LQ_AI_PUBLIC_HOST=private.invalid
LQ_AI_ACME_EMAIL=unused@private.invalid
LQ_AI_DNS_PROVIDER=hetzner
LQ_AI_DNS_API_TOKEN=unused

# --- Gateway config + provider keys ------------------------------------------
# Path ON THE BOX to this stack's gateway.yaml seed (see runbook §4 — the named
# volume holds the live, writable copy after first boot).
GATEWAY_CONFIG_FILE=/opt/lq-ai/gateway.yaml
# Runtime model egress is gateway-only. Under the private profile the expected
# posture is the Azure pairs below (Private-Link-able endpoints); any other
# provider key widens the egress inventory — clear it with whoever signs off
# on the environment's network policy first.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_RESOURCE=
# Azure AI Foundry — Claude (AZ-CONFIG; agent-capable since AZ-2b). Resource
# NAME only (the <your-resource> part of https://<your-resource>.services.ai.azure.com).
AZURE_ANTHROPIC_API_KEY=
AZURE_ANTHROPIC_RESOURCE=
# Azure AI Foundry — non-OpenAI Foundry Models (e.g. Mistral-Large-3).
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_RESOURCE=
# OPTIONAL (KV-1, ADR-F069) — source the three Azure keys from Azure Key Vault
# via the VM's managed identity instead of the plaintext vars above. All
# NON-secret (names only); leave a pair unset to keep its plain env var.
# Adds <vault>.vault.azure.net + link-local IMDS to the egress inventory
# (runbook §8 table). See runbook §4b.
# AZURE_KEY_VAULT_NAME=<your-vault-name>
# AZURE_OPENAI_KEY_SECRET_NAME=<secret-name-holding-the-azure-openai-key>
# AZURE_ANTHROPIC_KEY_SECRET_NAME=<secret-name-holding-the-azure-anthropic-key>
# AZURE_FOUNDRY_KEY_SECRET_NAME=<secret-name-holding-the-azure-foundry-key>
# PRC fence (ADR-F060) — keep unset.
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=

# --- Retrieval (ADR-F049 C1/D) — local ONNX = $0, ZERO retrieval egress -------
EMBEDDING_PROVIDER=local
RERANK_ENABLED=true

# --- Auth + notification email (SETUP-2) -------------------------------------
FIRST_RUN_ADMIN_EMAIL=admin@example.com
FIRST_RUN_OPERATOR_EMAIL=operator@example.com
# PUBLIC_BASE_URL for emailed invite/reset links — leave unset to derive
# https://${LQ_AI_PUBLIC_ORIGIN} (= https://127.0.0.1:8443, correct for tunnel
# users). With SMTP unset the invite-create response hands the accept URL back
# for out-of-band delivery anyway.
# PUBLIC_BASE_URL=
# SMTP is OFF by default here — an SMTP relay is additional egress; enable only
# with the environment's signoff (then add the relay to the §8 egress table).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# --- Auth / rate-limit knobs (secure code defaults; tune under attack) --------
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=604800
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_IP_PER_WINDOW=10
RATE_LIMIT_LOGIN_ACCOUNT_PER_WINDOW=5
RATE_LIMIT_REFRESH_IP_PER_WINDOW=60
RATE_LIMIT_MFA_VERIFY_IP_PER_WINDOW=10
RATE_LIMIT_MFA_VERIFY_ACCOUNT_PER_WINDOW=5
RATE_LIMIT_CHANGE_PASSWORD_ACCOUNT_PER_WINDOW=5
RATE_LIMIT_MFA_MANAGE_ACCOUNT_PER_WINDOW=10
RATE_LIMIT_BOOTSTRAP_STATUS_IP_PER_WINDOW=30
INVITE_TOKEN_TTL_SECONDS=604800
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600
RATE_LIMIT_PASSWORD_RESET_REQUEST_IP_PER_WINDOW=10
RATE_LIMIT_PASSWORD_RESET_REQUEST_EMAIL_PER_WINDOW=5
RATE_LIMIT_TOKEN_REDEEM_IP_PER_WINDOW=10
# SETUP-5a (ADR-F063) — deployment default budget profile (economy | balanced |
# generous). Empty ⇒ balanced.
RUN_DEFAULT_BUDGET_PROFILE=

# --- White-label branding seed (BRAND-1a, ADR-F068; optional) -----------------
BRAND_PRODUCT_NAME=
BRAND_ACCENT_LIGHT=
BRAND_ACCENT_DARK=

# --- Trusted proxy + CORS ----------------------------------------------------
# Caddy still fronts api + web same-origin (just on loopback TLS), so the
# public-path posture is unchanged: proxy headers trusted in-stack, no CORS.
FORWARDED_ALLOW_IPS=*
LQ_AI_CORS_ORIGINS=

# --- Collabora extras --------------------------------------------------------
# Caddy terminates TLS (internal CA) in front — same as the public path.
# The reduced 8-GiB profile (staging-bringup.md) composes on top and DROPS
# Collabora; by default it stays in the private profile.
COLLABORA_SSL_TERMINATION=true
COLLABORA_HOME_MODE=true

# --- Observability (opt-in; an OTLP/Langfuse endpoint is additional egress —
# leave unset in a restricted-egress environment unless signed off) -----------
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# --- Backups + ops (read by scripts/backup.sh|restore-drill.sh, NOT compose) --
# Single-node MinIO on the same disk means backups matter MORE here, not less
# (runbook §8 durability note). backup.sh targets an S3-compatible destination;
# a backup bucket OFF this box is strongly recommended (and is then an egress-
# inventory line of its own).
LQ_AI_TENANT_ID=REPLACE_ME__stack_id
LQ_AI_BACKUP_AGE_RECIPIENT=age1REPLACE_ME__public_recipient
LQ_AI_BACKUP_DEADMAN_URL=
LQ_AI_RESTORE_DEADMAN_URL=
LQ_AI_STACK_DIR=/opt/lq-ai
COMPOSE_PROJECT_NAME=lq-ai
# NOTE: restore-drill.sh also needs LQ_AI_BACKUP_AGE_IDENTITY (the PRIVATE key
# file path). Provide it AD HOC when running a drill — do NOT persist the private
# key in this file.

# --- Postgres/Redis identity (defaults; override only if you must) -----------
POSTGRES_DB=lq_ai
POSTGRES_USER=lq_ai
