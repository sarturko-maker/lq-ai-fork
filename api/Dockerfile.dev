# syntax=docker/dockerfile:1.7
# Development image — extends the production base with dev extras
# (pytest, respx, pytest-cov, etc.) so the test suite runs in-container.
#
# Usage:
#   docker build -f api/Dockerfile.dev -t lq-ai-api-dev api/
#   docker run --rm lq-ai-api-dev python -m pytest tests/ -x
#
# Or via docker compose override (see docs/dev-compose-override.example.yml):
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up api
#
# Production image (api/Dockerfile) installs only runtime deps (pip install .)
# to keep the surface area small.  This dev image adds [dev] extras on top of
# the same base so the two images stay byte-compatible at the application layer.

FROM python:3.12-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

# Install runtime + dev deps from pyproject.toml in a single pip invocation.
# The [dev] extra adds pytest, pytest-asyncio, pytest-cov, respx, and
# factory-boy (see pyproject.toml [project.optional-dependencies]).
COPY pyproject.toml README.md ./
RUN pip install --no-cache-dir ".[dev]"
# C4 (ADR-F031): Adeu --no-deps (see api/Dockerfile — avoids the fastmcp/starlette conflict).
RUN pip install --no-cache-dir --no-deps "adeu==1.12.1"

# Copy application code and migration files
COPY app/ ./app/
COPY alembic.ini ./alembic.ini
COPY alembic/ ./alembic/
COPY tests/ ./tests/

EXPOSE 8000

# Default entrypoint runs the test suite; override for interactive use.
CMD ["python", "-m", "pytest", "tests/", "-x", "--tb=short"]
